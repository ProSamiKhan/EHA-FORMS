{
  "entities": {
    "UserAccount": {
      "title": "User Account",
      "description": "User account information for authentication and role-based access.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "username": { "type": "string", "description": "Display username" },
        "email": { "type": "string", "description": "User email" },
        "role": { "type": "string", "enum": ["super_admin", "admin", "viewer"], "description": "User role" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "role"]
    },
    "Registration": {
      "title": "Registration",
      "description": "Student registration data.",
      "type": "object",
      "properties": {
        "admission_id": { "type": "string" },
        "name": { "type": "string" },
        "age": { "type": "string" },
        "gender": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "qualification": { "type": "string" },
        "medium": { "type": "string" },
        "status": { "type": "string", "enum": ["confirm", "pending", "cancelled", "stay only"] },
        "payment_status": { "type": "string", "enum": ["full paid", "partial", "unpaid", "refund"] },
        "total_fees": { "type": "string" },
        "remaining_amount": { "type": "string" },
        "discount": { "type": "string" },
        "date": { "type": "string" }
      },
      "required": ["name", "admission_id", "status"]
    },
    "AppConfig": {
      "title": "App Configuration",
      "description": "Global application settings.",
      "type": "object",
      "properties": {
        "appName": { "type": "string" },
        "appSubtitle": { "type": "string" },
        "logoUrl": { "type": "string" },
        "adminEmail": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserAccount",
      "description": "User profile documents."
    },
    "/registrations/{id}": {
      "schema": "Registration",
      "description": "Student registration records."
    },
    "/config/global": {
      "schema": "AppConfig",
      "description": "Global application configuration."
    }
  }
}
